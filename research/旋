    "    ax.set_thetagrids(np.degrees(angles[:-1]), labels)\n",
    "    ax.set_ylim(0,1)\n",
    "    ax.set_title(f\"Performance Radar — {head}\", y=1.08, fontsize=13, fontweight='bold')\n",
