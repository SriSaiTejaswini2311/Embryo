    "# ===== Evaluate two multi-output models & produce publication-ready visuals =====\n",
    "import os, sys, math, numpy as np, pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import confusion_matrix, classification_report, f1_score, accuracy_score\n",
    "from PIL import Image\n",
    "import tensorflow as tf\n",
    "\n",
    "# ---------- USER CONFIG ----------\n",
    "CSV_PATH = \"/kaggle/input/human-blastocyst-dataset-for-ivf/Gardner_train_silver.csv\"  # adjust if needed\n",
    "IMAGE_DIR = \"/kaggle/input/human-blastocyst-dataset-for-ivf/Images/Images\"            # folder containing images\n",
    "MODEL_A_PATH = \"/kaggle/working/models/efficientnetB3_gru_final.keras\"  # EfficientNet model file path\n",
    "MODEL_B_PATH = \"/kaggle/working/models/resnet50_gru_final.keras\"          # ResNet model file path\n",
    "IMG_SIZE = (224,224)\n",
    "BATCH_SIZE = 32\n",
    "OUTPUT_DIR = \"/kaggle/working/eval_outputs\"\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "# Label lists (adjust if your dataset maps differently)\n",
    "EXP_LABELS = [1,2,3,4,5]    # length 5\n",
    "ICM_LABELS = [1,2,3,4]      # length 4\n",
    "TE_LABELS  = [1,2,3,4]      # length 4\n",
    "\n",
    "# ---------- Helpers ----------\n",
    "def read_csv(csv_path):\n",
    "    df = pd.read_csv(csv_path, sep=';', engine='python')\n",
    "    if len(df.columns)==1: df = pd.read_csv(csv_path, sep=';', engine='python')\n",
    "    df.columns = [\"Image\",\"EXP_silver\",\"ICM_silver\",\"TE_silver\"]\n",
    "    # Build full path\n",
    "    df['image_path'] = df['Image'].apply(lambda x: os.path.join(IMAGE_DIR, x))\n",
    "    # Keep only existings\n",
    "    df = df[df['image_path'].apply(os.path.exists)].reset_index(drop=True)\n",
    "    return df\n",
    "\n",
    "def load_and_preprocess(path, size=IMG_SIZE, preprocess_fn=None):\n",
    "    img = Image.open(path).convert(\"RGB\").resize(size, Image.BILINEAR)\n",
    "    arr = np.asarray(img, dtype=np.float32)\n",
    "    if preprocess_fn is not None:\n",
    "        arr = preprocess_fn(arr)\n",
    "    return arr\n",
    "\n",
    "def batched_predict(model, filepaths, preprocess_fn):\n",
    "    # yields three arrays: preds_exp, preds_icm, preds_te (shape (N, n_classes))\n",
    "    N = len(filepaths)\n",
    "    exp_preds, icm_preds, te_preds = [], [], []\n",
    "    for i in range(0, N, BATCH_SIZE):\n",
    "        batch_paths = filepaths[i:i+BATCH_SIZE]\n",
    "        batch_imgs = np.stack([load_and_preprocess(p, preprocess_fn=preprocess_fn) for p in batch_paths])\n",
    "        preds = model.predict(batch_imgs, verbose=0)\n",
    "        # Ensure order: preds is list of 3 arrays (exp, icm, te)\n",
    "        if isinstance(preds, list) and len(preds) == 3:\n",
    "            exp_preds.append(preds[0])\n",
    "            icm_preds.append(preds[1])\n",
    "            te_preds.append(preds[2])\n",
    "        else:\n",
    "            # sometimes returns tuple; attempt to unpack\n",
    "            exp_preds.append(preds[0]); icm_preds.append(preds[1]); te_preds.append(preds[2])\n",
    "    exp_preds = np.vstack(exp_preds)\n",
    "    icm_preds = np.vstack(icm_preds)\n",
    "    te_preds  = np.vstack(te_preds)\n",
    "    return exp_preds, icm_preds, te_preds\n",
    "\n",
    "# ---------- Load dataset ----------\n",
    "df = read_csv(CSV_PATH)\n",
    "print(\"Images loaded:\", len(df))\n",
    "# For evaluation use a validation/test subset — if your CSV is the whole data, change accordingly.\n",
    "# Here we will evaluate on the whole set filtered above.\n",
    "filepaths = df['image_path'].tolist()\n",
    "yE = df['EXP_silver'].astype(int).tolist()\n",
    "yI = df['ICM_silver'].astype(int).tolist()\n",
    "yT = df['TE_silver'].astype(int).tolist()\n",
    "\n",
    "# Map ground-truth to 0-based indices matching model outputs\n",
    "# Assumes your labels in CSV are numbers matching EXP_LABELS etc.\n",
    "label_to_index_exp = {lab:i for i,lab in enumerate(EXP_LABELS)}\n",
    "label_to_index_icm = {lab:i for i,lab in enumerate(ICM_LABELS)}\n",
    "label_to_index_te  = {lab:i for i,lab in enumerate(TE_LABELS)}\n",
    "yE_idx = np.array([label_to_index_exp.get(v, 0) for v in yE], dtype=np.int32)\n",
    "yI_idx = np.array([label_to_index_icm.get(v, 0) for v in yI], dtype=np.int32)\n",
    "yT_idx = np.array([label_to_index_te.get(v, 0) for v in yT], dtype=np.int32)\n",
    "\n",
    "# ---------- Load models ----------\n",
    "print(\"Loading models (this may take a moment)...\")\n",
    "modelA = tf.keras.models.load_model(MODEL_A_PATH, compile=False)  # EfficientNet\n",
    "modelB = tf.keras.models.load_model(MODEL_B_PATH, compile=False)  # ResNet\n",
    "print(\"Models loaded.\")\n",
    "\n",
    "# Choose preprocess functions appropriate to each architecture\n",
    "from tensorflow.keras.applications.efficientnet import preprocess_input as preprocess_efficientnet\n",
    "from tensorflow.keras.applications.resnet50 import preprocess_input as preprocess_resnet\n",
    "\n",
    "# ---------- Predict with both models ----------\n",
    "print(\"Running predictions for Model A (EfficientNet)...\")\n",
    "expA, icmA, teA = batched_predict(modelA, filepaths, preprocess_fn=preprocess_efficientnet)\n",
    "print(\"Running predictions for Model B (ResNet)...\")\n",
    "expB, icmB, teB = batched_predict(modelB, filepaths, preprocess_fn=preprocess_resnet)\n",
    "\n",
    "# Convert to predicted indices\n",
    "predE_A = np.argmax(expA, axis=1)\n",
    "predI_A = np.argmax(icmA, axis=1)\n",
    "predT_A = np.argmax(teA, axis=1)\n",
    "\n",
    "predE_B = np.argmax(expB, axis=1)\n",
    "predI_B = np.argmax(icmB, axis=1)\n",
    "predT_B = np.argmax(teB, axis=1)\n",
    "\n",
    "# ---------- Per-head classification reports & confusion matrices ----------\n",
    "def save_confusion_and_report(y_true, pred, labels, head_name, model_name):\n",
    "    cm = confusion_matrix(y_true, pred, labels=list(range(len(labels))))\n",
    "    # plot confusion matrix (publication-style)\n",
    "    fig, ax = plt.subplots(figsize=(5,4))\n",
    "    im = ax.imshow(cm, interpolation='nearest', cmap='Blues')\n",
    "    ax.set_title(f\"{head_name} Confusion — {model_name}\")\n",
    "    ax.set_xlabel(\"Predicted\")\n",
    "    ax.set_ylabel(\"True\")\n",
    "    ax.set_xticks(np.arange(len(labels))); ax.set_yticks(np.arange(len(labels)))\n",
    "    ax.set_xticklabels([str(l) for l in labels]); ax.set_yticklabels([str(l) for l in labels])\n",
    "    plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)\n",
    "    # annotate\n",
    "    thresh = cm.max() / 2\n",
    "    for i in range(cm.shape[0]):\n",
    "        for j in range(cm.shape[1]):\n",
    "            ax.text(j, i, format(cm[i, j], 'd'),\n",
    "                    ha=\"center\", va=\"center\",\n",
    "                    color=\"white\" if cm[i, j] > thresh else \"black\")\n",
