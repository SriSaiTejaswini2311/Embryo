    "# Radar charts per head (EfficientNet+GRU vs ResNet+GRU)\n",
    "import os, numpy as np, pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import accuracy_score, f1_score, cohen_kappa_score\n",
    "from IPython.display import Image, display\n",
    "\n",
    "# ---------- Config ----------\n",
    "PRED_CSV = \"/kaggle/working/eval_outputs/per_image_predictions.csv\"  # ensure this exists\n",
    "OUT_DIR = \"/kaggle/working/eval_outputs/radar_outputs\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "if not os.path.exists(PRED_CSV):\n",
    "    raise FileNotFoundError(f\"Predictions CSV not found at {PRED_CSV}\")\n",
    "\n",
    "df = pd.read_csv(PRED_CSV)\n",
    "\n",
    "# Heads mapping: ground-truth, EfficientNet preds, ResNet preds\n",
    "heads = {\n",
    "    \"EXP\": {\"gt\":\"gt_EXP\", \"Eff\":\"Eff_EXP_pred\", \"Res\":\"Res_EXP_pred\"},\n",
    "    \"ICM\": {\"gt\":\"gt_ICM\", \"Eff\":\"Eff_ICM_pred\", \"Res\":\"Res_ICM_pred\"},\n",
    "    \"TE\":  {\"gt\":\"gt_TE\",  \"Eff\":\"Eff_TE_pred\",  \"Res\":\"Res_TE_pred\"}\n",
    "}\n",
    "\n",
    "# Compute metrics used in the radar\n",
    "def compute_metrics(y_true, y_pred):\n",
    "    y_true = np.array(y_true)\n",
    "    y_pred = np.array(y_pred)\n",
    "    m = {}\n",
    "    m['Accuracy'] = accuracy_score(y_true, y_pred)\n",
    "    m['Macro-F1'] = f1_score(y_true, y_pred, average='macro', zero_division=0)\n",
    "    m['Weighted-F1'] = f1_score(y_true, y_pred, average='weighted', zero_division=0)\n",
    "    try:\n",
    "        m['Kappa'] = float(cohen_kappa_score(y_true, y_pred))\n",
    "    except Exception:\n",
    "        m['Kappa'] = 0.0\n",
    "    return m\n",
    "\n",
    "# Metrics order displayed on radar\n",
    "metrics_order = ['Accuracy','Macro-F1','Weighted-F1','Kappa','Agreement']\n",
    "\n",
    "# Build metrics table (Eff & Res) and save CSV\n",
    "rows = []\n",
    "for head, cols in heads.items():\n",
    "    gt = df[cols['gt']].values\n",
    "    eff_pred = df[cols['Eff']].values\n",
    "    res_pred = df[cols['Res']].values\n",
    "    eff_m = compute_metrics(gt, eff_pred)\n",
    "    res_m = compute_metrics(gt, res_pred)\n",
    "    agreement = float(np.mean(eff_pred == res_pred))\n",
    "    eff_m['Agreement'] = agreement\n",
    "    res_m['Agreement'] = agreement\n",
