    "# Complete Grad-CAM + improved smoothing/overlay pipeline\n",
    "# Copy-paste and run in your Kaggle notebook.\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import tensorflow as tf\n",
    "from PIL import Image\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.cm as cm\n",
    "import cv2\n",
    "\n",
    "# ---------------- USER CONFIG ----------------\n",
    "MODEL_PATH = \"/kaggle/working/models/efficientnetB3_gru_final.keras\"  # your model (.keras)\n",
    "IMAGE_PATH = \"/kaggle/input/human-blastocyst-dataset-for-ivf/Images/Images/0001_02.png\"\n",
    "# IMAGE_PATH can also be a directory; the script will process all images in it if so.\n",
    "OUT_DIR = \"/kaggle/working/gradcam_outputs_improved\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "# Use 'exp','icm','te' or None to run all\n",
    "HEAD_NAME = None         # e.g., \"icm\" or None to process all heads\n",
    "CLASS_INDEX = None       # set integer to target class, or None to use predicted class\n",
    "IMG_SIZE = (224, 224)    # model input size\n",
    "LAST_CONV_LAYER = \"top_activation\"  # chosen from your model inspector\n",
    "ALPHA = 0.55             # max overlay alpha\n",
    "THRESHOLD = 0.12         # heatmap threshold for display (0..1)\n",
    "# ---------------------------------------------\n",
    "\n",
    "# Preprocessor for EfficientNet inputs\n",
    "from tensorflow.keras.applications.efficientnet import preprocess_input as preprocess_e\n",
    "\n",
    "# Load model\n",
    "print(\"Loading model:\", MODEL_PATH)\n",
    "model = tf.keras.models.load_model(MODEL_PATH, compile=False)\n",
    "print(\"Model loaded. Input shape:\", model.input_shape)\n",
    "print(\"Using last conv layer:\", LAST_CONV_LAYER)\n",
    "\n",
    "# Map head names to model output indices\n",
    "head_to_index = {\"exp\": 0, \"icm\": 1, \"te\": 2}\n",
    "if HEAD_NAME is None:\n",
    "    heads_to_run = [\"exp\", \"icm\", \"te\"]\n",
    "else:\n",
    "    if HEAD_NAME not in head_to_index:\n",
    "        raise ValueError(\"HEAD_NAME must be one of 'exp','icm','te' or None\")\n",
    "    heads_to_run = [HEAD_NAME]\n",
    "\n",
    "# Utility: load & preprocess image\n",
    "def load_and_preprocess(path, size=IMG_SIZE):\n",
    "    pil = Image.open(path).convert(\"RGB\").resize(size, Image.BILINEAR)\n",
    "    arr = np.array(pil).astype(\"float32\")\n",
    "    arr = preprocess_e(arr)  # EfficientNet preprocessing\n",
    "    return pil, np.expand_dims(arr, axis=0)\n",
    "\n",
    "# Smooth resize heatmap: bicubic + gaussian blur\n",
    "def smooth_resize_heatmap(heatmap, target_size, blur_ksize=(7,7), blur_sigma=0):\n",
    "    # heatmap: 2D float array 0..1\n",
    "    h_uint8 = (heatmap * 255).astype(np.uint8)\n",
    "    # target_size expects (width,height) for cv2\n",
    "    target_w, target_h = target_size\n",
    "    resized = cv2.resize(h_uint8, (target_w, target_h), interpolation=cv2.INTER_CUBIC)\n",
    "    if blur_ksize is not None:\n",
    "        resized = cv2.GaussianBlur(resized, blur_ksize, blur_sigma)\n",
    "    return resized.astype(np.float32) / 255.0\n",
    "\n",
    "# Overlay with per-pixel alpha mask and thresholding\n",
    "def overlay_with_threshold(pil_img, heatmap_resized, alpha=ALPHA, cmap_name='jet', threshold=THRESHOLD):\n",
    "    # heatmap_resized: 2D float array shape = (H, W), values 0..1\n",
    "    h = np.clip(heatmap_resized, 0.0, 1.0)\n",
    "    w, hh = pil_img.size\n",
    "    if h.shape != (hh, w):\n",
    "        h = cv2.resize((h*255).astype(np.uint8), (w, hh), interpolation=cv2.INTER_CUBIC).astype(np.float32)/255.0\n",
    "\n",
    "    # soft mask with threshold\n",
    "    mask = (h >= threshold).astype(np.float32) * (h - threshold) / max(1e-8, (1.0 - threshold))\n",
    "    mask = cv2.GaussianBlur((mask*255).astype(np.uint8), (5,5), 0).astype(np.float32)/255.0\n",
    "\n",
    "    cmap = cm.get_cmap(cmap_name)\n",
    "    colored = cmap(h)[:,:,:3]  # RGB 0..1\n",
    "    img_arr = np.array(pil_img).astype(np.float32) / 255.0\n",
    "    per_pixel_alpha = (mask * alpha)[:,:,np.newaxis]\n",
    "    overlay_rgb = (1 - per_pixel_alpha) * img_arr + per_pixel_alpha * colored\n",
    "    overlay_img = Image.fromarray((overlay_rgb * 255).astype(np.uint8))\n",
    "    return overlay_img, mask\n",
    "\n",
    "# Grad-CAM computation for a given head and class index\n",
    "def compute_gradcam_for_head(model, img_batch, head_idx, class_index, last_conv_name):\n",
    "    # Create a model returning conv features and the chosen head output\n",
    "    conv_layer = model.get_layer(last_conv_name).output\n",
    "    head_output = model.outputs[head_idx]  # shape (batch, n_classes)\n",
    "    grad_model = tf.keras.models.Model([model.inputs], [conv_layer, head_output])\n",
    "\n",
    "    with tf.GradientTape() as tape:\n",
    "        conv_outputs, preds_head = grad_model(img_batch)\n",
    "        tape.watch(conv_outputs)\n",
    "        target = preds_head[:, class_index]   # tensor of shape (batch,)\n",
    "        loss = target[0]                      # scalar for the first sample\n",
    "\n",
    "    grads = tape.gradient(loss, conv_outputs)   # (1, H, W, C)\n",
    "    if grads is None:\n",
    "        raise RuntimeError(\"Gradients are None. Check model graph or class_index.\")\n",
    "    pooled_grads = tf.reduce_mean(grads, axis=(0,1,2)).numpy()  # (C,)\n",
    "    conv_out = conv_outputs[0].numpy()  # (H, W, C)\n",
    "\n",
    "    # weigh channels\n",
    "    for i in range(pooled_grads.shape[-1]):\n",
    "        conv_out[:,:,i] *= pooled_grads[i]\n",
    "    heatmap = np.sum(conv_out, axis=-1)\n",
    "    heatmap = np.maximum(heatmap, 0)\n",
    "    if np.max(heatmap) != 0:\n",
    "        heatmap /= np.max(heatmap)\n",
    "    return heatmap  # 2D 0..1\n",
    "\n",
    "# Build list of images\n",
    "img_paths = []\n",
    "if os.path.isdir(IMAGE_PATH):\n",
    "    for fn in sorted(os.listdir(IMAGE_PATH)):\n",
    "        if fn.lower().endswith(('.png','.jpg','.jpeg','tif','tiff')):\n",
    "            img_paths.append(os.path.join(IMAGE_PATH, fn))\n",
    "else:\n",
    "    img_paths = [IMAGE_PATH]\n",
    "\n",
    "print(\"Images to process:\", len(img_paths))\n",
    "\n",
    "# Process each image\n",
    "for img_path in img_paths:\n",
    "    base = os.path.basename(img_path)\n",
    "    name, ext = os.path.splitext(base)\n",
    "    pil_img, img_batch = load_and_preprocess(img_path, size=IMG_SIZE)\n",
    "    preds = model.predict(img_batch, verbose=0)  # list of outputs (exp, icm, te)\n",
    "    print(\"\\nProcessing:\", base)\n",
    "\n",
    "    for head in heads_to_run:\n",
    "        hi = head_to_index[head]\n",
    "        head_preds = preds[hi][0]  # array of probs or logits\n",
    "        chosen = int(np.argmax(head_preds)) if CLASS_INDEX is None else int(CLASS_INDEX)\n",
    "        conf = float(head_preds[chosen])\n",
    "        print(f\"  head: {head} | chosen class: {chosen} | conf: {conf:.4f}\")\n",
    "\n",
    "        # compute gradcam heatmap (low-res)\n",
    "        heatmap = compute_gradcam_for_head(model, img_batch, hi, chosen, LAST_CONV_LAYER)\n",
    "\n",
    "        # upscale and smooth heatmap to image size\n",
    "        target_size = pil_img.size  # (width, height)\n",
    "        heat_up = smooth_resize_heatmap(heatmap, target_size, blur_ksize=(7,7), blur_sigma=0)\n",
    "\n",
    "        # overlay with thresholding + smoothing\n",
    "        overlay_img, mask = overlay_with_threshold(pil_img, heat_up, alpha=ALPHA, cmap_name='jet', threshold=THRESHOLD)\n",
    "\n",
    "        # Save outputs (heatmap as grayscale and overlay)\n",
    "        heatmap_vis = (heat_up * 255).astype(np.uint8)\n",
    "        heatmap_path = os.path.join(OUT_DIR, f\"{name}_heatmap_{head}_c{chosen}_smooth.png\")\n",
    "        overlay_path = os.path.join(OUT_DIR, f\"{name}_overlay_{head}_c{chosen}_smooth.png\")\n",
    "        Image.fromarray(heatmap_vis).save(heatmap_path)\n",
    "        overlay_img.save(overlay_path)\n",
    "\n",
    "        print(\"   Saved:\", heatmap_path)\n",
    "        print(\"   Saved:\", overlay_path)\n",
    "\n",
    "        # Display inline: original | smoothed heatmap (jet) | overlay\n",
    "        plt.figure(figsize=(10,3.5))\n",
    "        plt.subplot(1,3,1); plt.imshow(pil_img); plt.title(\"Original\"); plt.axis(\"off\")\n",
    "        plt.subplot(1,3,2); plt.imshow(heat_up, cmap=\"jet\"); plt.title(\"Smoothed Heatmap\"); plt.axis(\"off\")\n",
    "        plt.subplot(1,3,3); plt.imshow(overlay_img); plt.title(\"Overlay\"); plt.axis(\"off\")\n",
    "        plt.suptitle(f\"{name} — {head} (class {chosen}) | conf={conf:.3f}\", fontsize=12)\n",
    "        plt.show()\n",
    "\n",
    "print(\"\\nAll outputs saved to:\", OUT_DIR)\n"
   ]
  }
