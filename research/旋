    "import os, numpy as np, pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Input: use the metrics_table.csv you already saved\n",
    "METRICS_PATH = \"/kaggle/working/eval_outputs/radar_outputs/metrics_table.csv\"\n",
    "OUT_PATH = \"/kaggle/working/eval_outputs/radar_outputs/combined_radar_all_heads.png\"\n",
    "\n",
    "# Load metrics table\n",
    "metrics_df = pd.read_csv(METRICS_PATH, index_col=0)\n",
    "heads = [\"EXP\", \"ICM\", \"TE\"]\n",
    "metrics_order = metrics_df.index.tolist()\n",
    "\n",
    "# Prepare angles for radar chart\n",
    "angles = np.linspace(0, 2*np.pi, len(metrics_order), endpoint=False)\n",
    "angles = np.concatenate((angles, [angles[0]]))  # close the loop\n",
    "\n",
    "# Figure setup\n",
    "fig, axes = plt.subplots(1, 3, subplot_kw=dict(polar=True), figsize=(15,5))\n",
    "plt.subplots_adjust(wspace=0.3)\n",
    "\n",
    "# Colors\n",
    "eff_color = \"#0072B2\"   # blue\n",
    "res_color = \"#E69F00\"   # orange\n",
    "\n",
    "# Loop through each head and plot\n",
    "for i, head in enumerate(heads):\n",
    "    ax = axes[i]\n",
    "    eff_vals = metrics_df[f\"Eff_{head}\"].values\n",
    "    res_vals = metrics_df[f\"Res_{head}\"].values\n",
    "    eff_vals = np.concatenate((eff_vals, [eff_vals[0]]))\n",
    "    res_vals = np.concatenate((res_vals, [res_vals[0]]))\n",
    "\n",
    "    ax.plot(angles, eff_vals, marker=\"o\", color=eff_color, linewidth=2, label=\"EfficientNet + GRU\")\n",
    "    ax.fill(angles, eff_vals, color=eff_color, alpha=0.2)\n",
    "    ax.plot(angles, res_vals, marker=\"s\", color=res_color, linewidth=2, linestyle=\"--\", label=\"ResNet + GRU\")\n",
    "    ax.fill(angles, res_vals, color=res_color, alpha=0.15)\n",
    "\n",
    "    ax.set_thetagrids(np.degrees(angles[:-1]), metrics_order)\n",
    "    ax.set_ylim(0,1)\n",
    "    ax.set_title(f\"{head} Head\", fontsize=13, fontweight=\"bold\", y=1.1)\n",
    "    ax.grid(True)\n",
