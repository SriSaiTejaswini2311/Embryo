    "import os, numpy as np, pandas as pd\n",
    "from sklearn.metrics import accuracy_score, f1_score, cohen_kappa_score\n",
    "\n",
    "# Paths\n",
    "PRED_CSV = \"/kaggle/working/eval_outputs/per_image_predictions.csv\"\n",
    "OUT_DIR = \"/kaggle/working/eval_outputs\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "df = pd.read_csv(PRED_CSV)\n",
    "\n",
    "# Heads\n",
    "heads = {\n",
    "    \"EXP\": {\"gt\":\"gt_EXP\", \"Eff\":\"Eff_EXP_pred\", \"Res\":\"Res_EXP_pred\"},\n",
    "    \"ICM\": {\"gt\":\"gt_ICM\", \"Eff\":\"Eff_ICM_pred\", \"Res\":\"Res_ICM_pred\"},\n",
    "    \"TE\":  {\"gt\":\"gt_TE\",  \"Eff\":\"Eff_TE_pred\",  \"Res\":\"Res_TE_pred\"}\n",
    "}\n",
    "\n",
    "def compute_metrics(y_true, y_pred):\n",
    "    return {\n",
    "        \"Accuracy\": accuracy_score(y_true, y_pred),\n",
    "        \"Macro-F1\": f1_score(y_true, y_pred, average='macro', zero_division=0),\n",
    "        \"Weighted-F1\": f1_score(y_true, y_pred, average='weighted', zero_division=0),\n",
    "        \"Kappa\": cohen_kappa_score(y_true, y_pred)\n",
    "    }\n",
    "\n",
    "# Collect results\n",
    "metrics = [\"Accuracy\", \"Macro-F1\", \"Weighted-F1\", \"Kappa\", \"Agreement\"]\n",
    "df_out = pd.DataFrame(index=metrics)\n",
    "\n",
    "for head, cols in heads.items():\n",
    "    y_true = df[cols[\"gt\"]]\n",
    "    eff_pred = df[cols[\"Eff\"]]\n",
    "    res_pred = df[cols[\"Res\"]]\n",
    "    eff = compute_metrics(y_true, eff_pred)\n",
    "    res = compute_metrics(y_true, res_pred)\n",
    "    agree = np.mean(eff_pred == res_pred)\n",
    "    eff[\"Agreement\"] = agree\n",
    "    res[\"Agreement\"] = agree\n",
    "\n",
    "    # Add subcolumns for Eff and Res\n",
    "    df_out[(head, \"EfficientNet + GRU\")] = [round(eff[m], 3) for m in metrics]\n",
    "    df_out[(head, \"ResNet + GRU\")] = [round(res[m], 3) for m in metrics]\n",
    "\n",
    "# Create multi-index columns\n",
    "df_out.columns = pd.MultiIndex.from_tuples(df_out.columns)\n",
    "df_out.index.name = \"Metric\"\n",
    "\n",
    "# Save\n",
    "csv_path = os.path.join(OUT_DIR, \"overall_results_grouped_bordered.csv\")\n",
    "tex_path = os.path.join(OUT_DIR, \"overall_results_grouped_bordered.tex\")\n",
    "df_out.to_csv(csv_path)\n",
    "with open(tex_path, \"w\") as f:\n",
    "    f.write(df_out.to_latex(index=True, multirow=True, float_format=\"%.3f\"))\n",
    "\n",
    "print(\"✅ Grouped bordered table saved to:\")\n",
    "print(csv_path)\n",
    "print(tex_path)\n",
    "df_out\n"
