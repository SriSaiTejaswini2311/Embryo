   "source": [
    "# efficientnet_gru_training_kaggle.py\n",
    "# Author: ChatGPT (GPT-5)\n",
    "# EfficientNetB3 + GRU Multi-Output Blastocyst Grading (EXP, ICM, TE)\n",
    "# Dataset: /kaggle/input/human-blastocyst-dataset-for-ivf\n",
    "\n",
    "import os, random, math, numpy as np, pandas as pd\n",
    "from tqdm import tqdm\n",
    "from PIL import Image\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers, Model\n",
    "from tensorflow.keras.applications import EfficientNetB3\n",
    "from tensorflow.keras.applications.efficientnet import preprocess_input\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "\n",
    "# ---------------- CONFIG ----------------\n",
    "DATA_DIR = \"/kaggle/input/human-blastocyst-dataset-for-ivf\"\n",
    "IMAGE_DIR = os.path.join(DATA_DIR, \"Images\", \"Images\")\n",
    "CSV_PATH = os.path.join(DATA_DIR, \"Gardner_train_silver.csv\")\n",
    "MODEL_SAVE_DIR = \"/kaggle/working/models\"\n",
    "os.makedirs(MODEL_SAVE_DIR, exist_ok=True)\n",
    "\n",
    "IMG_SIZE = (224, 224)\n",
    "BATCH_SIZE = 32\n",
    "EPOCHS = 25\n",
    "LR_HEAD, LR_FT = 1e-4, 1e-5\n",
    "OVERSAMPLE_EXP = [2, 3]\n",
    "SEED = 42\n",
    "tf.random.set_seed(SEED); np.random.seed(SEED); random.seed(SEED)\n",
    "\n",
    "# ---------------- DATA ----------------\n",
    "def read_csv(csv_path):\n",
    "    df = pd.read_csv(csv_path, sep=';', engine='python')\n",
    "    if len(df.columns) == 1:\n",
    "        df = pd.read_csv(csv_path, sep=';', engine='python')\n",
    "    df.columns = [\"Image\", \"EXP_silver\", \"ICM_silver\", \"TE_silver\"]\n",
    "    for c in [\"EXP_silver\", \"ICM_silver\", \"TE_silver\"]:\n",
    "        df[c] = pd.to_numeric(df[c], errors='coerce').astype(int)\n",
    "    df[\"image_path\"] = df[\"Image\"].apply(lambda x: os.path.join(IMAGE_DIR, x))\n",
    "    df = df[df[\"image_path\"].apply(os.path.exists)]\n",
    "    return df.reset_index(drop=True)\n",
    "\n",
    "def load_image(path):\n",
    "    img = Image.open(path).convert(\"RGB\").resize(IMG_SIZE)\n",
    "    return np.array(img, dtype=np.float32)\n",
    "\n",
    "def augment(img):\n",
    "    img = tf.convert_to_tensor(img / 255.0)\n",
    "    img = tf.image.random_flip_left_right(img)\n",
    "    img = tf.image.random_flip_up_down(img)\n",
    "    img = tf.image.random_contrast(img, 0.85, 1.15)\n",
    "    img = tf.image.random_brightness(img, 0.15)\n",
    "    img = tf.image.random_jpeg_quality(img, 70, 100)\n",
    "    img = tf.clip_by_value(img, 0, 1)\n",
    "    return (img.numpy() * 255.0).astype(np.float32)\n",
    "\n",
    "def oversample(df):\n",
    "    print(\"Balancing dataset...\")\n",
    "    X, e, i, t = [], [], [], []\n",
    "    for p in tqdm(df[\"image_path\"], desc=\"Loading images\"):\n",
    "        X.append(load_image(p))\n",
    "    X = np.array(X)\n",
    "    exp, icm, te = df[\"EXP_silver\"].values, df[\"ICM_silver\"].values, df[\"TE_silver\"].values\n",
    "    unique, counts = np.unique(exp, return_counts=True)\n",
    "    max_count = counts.max()\n",
    "    extraX, extraE, extraI, extraT = [], [], [], []\n",
    "    for g in OVERSAMPLE_EXP:\n",
    "        idx = np.where(exp == g)[0]\n",
    "        need = max_count - len(idx)\n",
    "        for _ in range(need):\n",
    "            pick = random.choice(idx)\n",
    "            aug = augment(X[pick])\n",
    "            extraX.append(aug)\n",
    "            extraE.append(exp[pick]); extraI.append(icm[pick]); extraT.append(te[pick])\n",
    "    if extraX:\n",
    "        X = np.concatenate([X, np.stack(extraX)]); \n",
    "        exp=np.concatenate([exp,extraE]); icm=np.concatenate([icm,extraI]); te=np.concatenate([te,extraT])\n",
    "    idx=np.arange(len(X)); np.random.shuffle(idx)\n",
    "    return X[idx], exp[idx], icm[idx], te[idx]\n",
    "\n",
    "# ---------------- MODEL ----------------\n",
    "def build_efficientnet_gru(input_shape=(224, 224, 3)):\n",
    "    inp = layers.Input(shape=input_shape)\n",
    "    base = EfficientNetB3(include_top=False, weights=\"imagenet\", input_tensor=inp)\n",
    "    x = base.output\n",
    "    x = layers.GlobalAveragePooling2D()(x)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.Reshape((1, x.shape[-1]))(x)\n",
    "    x = layers.GRU(256)(x)\n",
    "    x = layers.Dense(512, activation=\"relu\")(x)\n",
    "    x = layers.Dropout(0.4)(x)\n",
    "    exp = layers.Dense(5, activation=\"softmax\", name=\"exp_output\")(x)\n",
    "    icm = layers.Dense(4, activation=\"softmax\", name=\"icm_output\")(x)\n",
