    "    \"TE\" : { \"gt_col\":\"gt_TE\",  \"A_pred\":\"Eff_TE_pred\",  \"B_pred\":\"Res_TE_pred\" }\n",
    "}\n",
    "\n",
    "# Metrics to compute: Accuracy, Macro-F1, Weighted-F1, Cohen's Kappa, Agreement Rate\n",
    "def compute_metrics(y_true, yA, yB):\n",
    "    # expects labels as numbers (matching how preds were saved)\n",
    "    y_true = np.array(y_true)\n",
    "    yA = np.array(yA)\n",
    "    yB = np.array(yB)\n",
    "    metricsA = {}\n",
    "    metricsB = {}\n",
    "    # Accuracy\n",
    "    metricsA['Accuracy'] = accuracy_score(y_true, yA)\n",
    "    metricsB['Accuracy'] = accuracy_score(y_true, yB)\n",
    "    # Macro F1\n",
    "    metricsA['Macro-F1'] = f1_score(y_true, yA, average='macro', zero_division=0)\n",
    "    metricsB['Macro-F1'] = f1_score(y_true, yB, average='macro', zero_division=0)\n",
    "    # Weighted F1\n",
    "    metricsA['Weighted-F1'] = f1_score(y_true, yA, average='weighted', zero_division=0)\n",
    "    metricsB['Weighted-F1'] = f1_score(y_true, yB, average='weighted', zero_division=0)\n",
    "    # Cohen's Kappa (agreement with ground truth)\n",
    "    try:\n",
    "        metricsA['Kappa'] = cohen_kappa_score(y_true, yA)\n",
    "    except Exception:\n",
    "        metricsA['Kappa'] = 0.0\n",
    "    try:\n",
    "        metricsB['Kappa'] = cohen_kappa_score(y_true, yB)\n",
    "    except Exception:\n",
    "        metricsB['Kappa'] = 0.0\n",
    "    # Agreement between models (how often they predict same class)\n",
    "    metricsA['Agreement'] = np.mean(yA == yB)\n",
    "    metricsB['Agreement'] = metricsA['Agreement']  # same for both, included for plotting\n",
