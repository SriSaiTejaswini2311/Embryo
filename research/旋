    "\n",
    "# Heads configuration: column names for gt and two models' predictions\n",
    "heads = {\n",
    "    \"EXP\": { \"gt_col\":\"gt_EXP\", \"A_pred\":\"Eff_EXP_pred\", \"B_pred\":\"Res_EXP_pred\" },\n",
