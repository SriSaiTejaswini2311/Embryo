    "# resnet_gru_training_kaggle.py\n",
    "# Author: ChatGPT (GPT-5)\n",
    "# ResNet50 + GRU Multi-Output Blastocyst Grading (EXP, ICM, TE)\n",
    "\n",
    "import os, random, numpy as np, pandas as pd\n",
    "from tqdm import tqdm\n",
    "from PIL import Image\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers, Model\n",
    "from tensorflow.keras.applications import ResNet50\n",
    "from tensorflow.keras.applications.resnet50 import preprocess_input\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# ---------------- CONFIG ----------------\n",
    "DATA_DIR = \"/kaggle/input/human-blastocyst-dataset-for-ivf\"\n",
    "IMAGE_DIR = os.path.join(DATA_DIR, \"Images\", \"Images\")\n",
    "CSV_PATH = os.path.join(DATA_DIR, \"Gardner_train_silver.csv\")\n",
    "MODEL_SAVE_DIR = \"/kaggle/working/models\"\n",
    "os.makedirs(MODEL_SAVE_DIR, exist_ok=True)\n",
    "\n",
    "IMG_SIZE = (224,224)\n",
    "BATCH_SIZE = 32\n",
    "EPOCHS = 25\n",
    "LR_HEAD, LR_FT = 1e-4, 1e-5\n",
    "SEED = 42\n",
    "tf.random.set_seed(SEED); np.random.seed(SEED); random.seed(SEED)\n",
    "\n",
    "# ---------------- DATA ----------------\n",
    "def read_csv(path):\n",
    "    df = pd.read_csv(path, sep=';', engine='python')\n",
    "    if len(df.columns)==1: df = pd.read_csv(path, sep=';', engine='python')\n",
    "    df.columns=[\"Image\",\"EXP_silver\",\"ICM_silver\",\"TE_silver\"]\n",
    "    for c in [\"EXP_silver\",\"ICM_silver\",\"TE_silver\"]:\n",
    "        df[c]=pd.to_numeric(df[c],errors='coerce').astype(int)\n",
    "    df[\"image_path\"]=df[\"Image\"].apply(lambda x:os.path.join(IMAGE_DIR,x))\n",
    "    df=df[df[\"image_path\"].apply(os.path.exists)]\n",
    "    return df.reset_index(drop=True)\n",
    "\n",
    "def load_image(p): \n",
    "    return np.array(Image.open(p).convert(\"RGB\").resize(IMG_SIZE), dtype=np.float32)\n",
    "\n",
    "# ---------------- MODEL ----------------\n",
    "def build_resnet_gru(input_shape=(224,224,3)):\n",
    "    inp = layers.Input(shape=input_shape)\n",
    "    base = ResNet50(include_top=False, weights=\"imagenet\", input_tensor=inp)\n",
    "    x = base.output\n",
    "    x = layers.GlobalAveragePooling2D()(x)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.Reshape((1, x.shape[-1]))(x)\n",
    "    x = layers.GRU(256)(x)\n",
    "    x = layers.Dense(512, activation=\"relu\")(x)\n",
    "    x = layers.Dropout(0.4)(x)\n",
    "    exp = layers.Dense(5, activation=\"softmax\", name=\"exp_output\")(x)\n",
    "    icm = layers.Dense(4, activation=\"softmax\", name=\"icm_output\")(x)\n",
    "    te  = layers.Dense(4, activation=\"softmax\", name=\"te_output\")(x)\n",
    "    model = Model(inp, [exp, icm, te])\n",
    "    model.compile(optimizer=tf.keras.optimizers.Adam(LR_HEAD),\n",
    "                  loss={\"exp_output\":\"sparse_categorical_crossentropy\",\n",
    "                        \"icm_output\":\"sparse_categorical_crossentropy\",\n",
    "                        \"te_output\":\"sparse_categorical_crossentropy\"},\n",
    "                  metrics={\"exp_output\":\"accuracy\",\n",
    "                           \"icm_output\":\"accuracy\",\n",
    "                           \"te_output\":\"accuracy\"})\n",
    "    return model, base\n",
    "\n",
    "# ---------------- TRAIN ----------------\n",
    "def train_model():\n",
    "    df = read_csv(CSV_PATH)\n",
    "    tr, val = train_test_split(df, test_size=0.2, stratify=df[\"EXP_silver\"], random_state=SEED)\n",
    "    Xtr = np.stack([load_image(p) for p in tr[\"image_path\"]])\n",
    "    Xv = np.stack([load_image(p) for p in val[\"image_path\"]])\n",
    "    yE, yI, yT = tr[\"EXP_silver\"], tr[\"ICM_silver\"], tr[\"TE_silver\"]\n",
    "    yEv, yIv, yTv = val[\"EXP_silver\"], val[\"ICM_silver\"], val[\"TE_silver\"]\n",
    "    Xtr, Xv = preprocess_input(Xtr), preprocess_input(Xv)\n",
    "    model, base = build_resnet_gru()\n",
    "    es = tf.keras.callbacks.EarlyStopping(monitor=\"val_exp_output_accuracy\", patience=5, restore_best_weights=True, mode=\"max\")\n",
    "    rl = tf.keras.callbacks.ReduceLROnPlateau(monitor=\"val_loss\", factor=0.5, patience=3)\n",
    "    print(\"Stage 1: Training head (frozen backbone)\")\n",
    "    model.fit(Xtr, {\"exp_output\":yE,\"icm_output\":yI,\"te_output\":yT},\n",
    "              validation_data=(Xv,{\"exp_output\":yEv,\"icm_output\":yIv,\"te_output\":yTv}),\n",
    "              epochs=EPOCHS, batch_size=BATCH_SIZE, callbacks=[es,rl], verbose=2)\n",
    "    print(\"Stage 2: Fine-tuning top 150 layers\")\n",
    "    for l in base.layers[:-150]: l.trainable=False\n",
    "    for l in base.layers[-150:]: l.trainable=True\n",
    "    model.compile(optimizer=tf.keras.optimizers.Adam(LR_FT),\n",
    "                  loss={\"exp_output\":\"sparse_categorical_crossentropy\",\n",
    "                        \"icm_output\":\"sparse_categorical_crossentropy\",\n",
    "                        \"te_output\":\"sparse_categorical_crossentropy\"},\n",
    "                  metrics={\"exp_output\":\"accuracy\",\"icm_output\":\"accuracy\",\"te_output\":\"accuracy\"})\n",
    "    model.fit(Xtr, {\"exp_output\":yE,\"icm_output\":yI,\"te_output\":yT},\n",
    "              validation_data=(Xv,{\"exp_output\":yEv,\"icm_output\":yIv,\"te_output\":yTv}),\n",
    "              epochs=EPOCHS, batch_size=BATCH_SIZE, callbacks=[es,rl], verbose=2)\n",
    "    model.save(os.path.join(MODEL_SAVE_DIR, \"resnet50_gru_final.keras\"))\n",
    "    print(\"Model saved successfully!\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    train_model()\n"
